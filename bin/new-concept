#!/bin/bash
# Quick-capture script for new concepts
# Usage: bin/new-concept "Concept Title" [--source paper|book|chatgpt|internet|course] [--tags tag1,tag2]

set -e

CONCEPTS_DIR="$(cd "$(dirname "$0")/.." && pwd)/_concepts"
TODAY=$(date +%Y-%m-%d)

# Defaults
SOURCE="internet"
STATUS="seed"
TAGS=""
TITLE=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --source|-s)
      SOURCE="$2"
      shift 2
      ;;
    --tags|-t)
      TAGS="$2"
      shift 2
      ;;
    *)
      if [ -z "$TITLE" ]; then
        TITLE="$1"
      fi
      shift
      ;;
  esac
done

if [ -z "$TITLE" ]; then
  echo "Usage: bin/new-concept \"Concept Title\" [--source paper|book|chatgpt|internet|course] [--tags tag1,tag2]"
  exit 1
fi

# Generate slug from title
SLUG=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')

FILE="${CONCEPTS_DIR}/${SLUG}.md"

if [ -f "$FILE" ]; then
  echo "Concept already exists: $FILE"
  exit 1
fi

# Format tags as YAML array
if [ -n "$TAGS" ]; then
  TAG_YAML="[$(echo "$TAGS" | sed 's/,/, /g')]"
else
  TAG_YAML="[]"
fi

cat > "$FILE" << EOF
---
layout: concept
title: "${TITLE}"
date: ${TODAY}
tags: ${TAG_YAML}
source: ${SOURCE}
status: ${STATUS}
last_reviewed: ${TODAY}
---

- **What:**
- **Why:**
- **Key insight:**
EOF

echo "Created: $FILE"
echo "Status: seed | Source: $SOURCE"
